                                        <tspan x={cx} y={cy} dy="-5" fontSize="24" fontWeight="bold" fill={isDarkMode ? '#fff' : '#1e293b'}>
                                          {summary.lineItem.toLocaleString()}
                                        </tspan>
                                        <tspan x={cx} y={cy} dy="15" fontSize="12" fill="#94a3b8">
                                          รวมทั้งหมด
                                        </tspan>
                                      </text>
                                    );
                                  }
                                  return null;
                                }}
                                position="center"
                              />
                          </Pie>
                          <RechartsTooltip 
                              contentStyle={{ borderRadius: '12px', border: 'none', backgroundColor: isDarkMode ? '#1e293b' : '#fff', color: isDarkMode ? '#fff' : '#000', boxShadow: '0 10px 15px -3px rgba(0, 0, 0, 0.1)' }} 
                              formatter={(value, name) => {
                                  // คำนวณเป็นเปอร์เซ็นต์เทียบกับยอด Line Item ทั้งหมด
                                  const pct = summary.lineItem > 0 ? ((value / summary.lineItem) * 100).toFixed(1) : 0;
                                  return [`${pct}% (${value.toLocaleString()})`, name];
                              }}
                          />
                          <Legend layout="horizontal" verticalAlign="bottom" align="center" iconType="circle" />
                        </PieChart>
                      </ResponsiveContainer>
                    </div>
                 </div>

