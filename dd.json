                                     <span className="font-bold">{region.completePct}% <span className="text-[10px] text-emerald-600/60 dark:text-emerald-400/60 font-normal">({region.complete.toLocaleString()})</span></span>
                                 </div>
                                 <div className="text-rose-500 flex flex-col items-center">
                                     <span className="flex items-center gap-1"><XCircle size={12}/> Failed</span>
                                     <span className="font-bold">{region.failedPct}% <span className="text-[10px] text-rose-600/60 dark:text-rose-400/60 font-normal">({region.failed.toLocaleString()})</span></span>
                                 </div>
                                 <div className="text-amber-500 flex flex-col items-end">
                                     <span className="flex items-center gap-1"><Clock size={12}/> In Transit</span>
