                         return (
                         <tr key={index} className={`transition-colors group ${isDarkMode ? 'hover:bg-slate-700/30' : 'hover:bg-blue-50/40'}`}>
                           {headers.map((header, idx) => (
                             <td key={idx} className={`p-4 ${isDarkMode ? 'text-slate-300' : 'text-slate-700'} truncate max-w-[200px]`}>
                               {row[header]}
                             </td>
                           ))}
                         </tr>
                       )})
                     ) : (
                       <tr>
                         <td colSpan="10" className="p-16 text-center text-slate-400 font-medium text-lg">
                           {isLoading ? (
                               <span className="flex items-center justify-center gap-2"><RefreshCw className="animate-spin" /> กำลังโหลดข้อมูล...</span>
                           ) : 'ไม่พบข้อมูลตามเงื่อนไขที่เลือก กรุณาปรับเปลี่ยนตัวกรอง'}
                         </td>
                       </tr>
                     )}
                   </tbody>
                 </table>
               </div>
            </div>
          )}

          {activeTab === 'list' && !isAuthenticated && (
             <div className="flex flex-col items-center justify-center h-[70vh] text-center space-y-6">
                <div className="p-6 rounded-full bg-blue-50 dark:bg-slate-800 shadow-inner">
                   <Lock size={64} className="text-blue-500" />
                </div>
                <div>
                   <h3 className={`text-3xl font-black mb-2 ${isDarkMode ? 'text-white' : 'text-slate-800'}`}>พื้นที่จำกัดสิทธิ์</h3>
                   <p className="text-slate-500 font-medium">กรุณาเข้าสู่ระบบด้วยรหัสผ่านผู้ดูแลระบบ (1234) เพื่อดูและจัดการข้อมูลดิบ</p>
                </div>
                <button 
                  onClick={() => setShowLoginModal(true)}
                  className="px-8 py-3.5 bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white rounded-xl shadow-lg shadow-blue-500/30 transition-all font-bold text-lg hover:-translate-y-1"
                >
                  เข้าสู่ระบบ Admin
                </button>
             </div>
          )}

        </div>
      </main>
    </div>
  );
}
