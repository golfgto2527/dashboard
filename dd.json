// --- Login Modal ---
const LoginModal = ({ isOpen, onClose, onLogin, isDarkMode }) => {
  const [password, setPassword] = useState('');
  const [error, setError] = useState('');

  if (!isOpen) return null;

  const handleSubmit = (e) => {
    e.preventDefault();
    if (password === ADMIN_PASSWORD) {
      onLogin();
      setPassword('');
      setError('');
    } else {
      setError('รหัสผ่านไม่ถูกต้อง');
    }
  };

  return (
    <div className="fixed inset-0 z-[60] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
      <div className={`w-full max-w-sm p-8 rounded-2xl shadow-2xl ${isDarkMode ? 'bg-slate-800 text-white border border-slate-700' : 'bg-white text-slate-900'}`}>
        <div className="flex justify-between items-center mb-6">
          <h3 className="text-xl font-bold font-kanit flex items-center gap-2">
            <Lock size={20} className="text-blue-500" /> ยืนยันสิทธิ์เข้าถึง
          </h3>
          <button onClick={onClose} className="text-slate-400 hover:text-slate-500">
            <X size={20} />
          </button>
        </div>
        <form onSubmit={handleSubmit} className="space-y-4">
          <div>
            <label className="block text-sm font-medium mb-1 font-kanit">รหัสผ่านสำหรับ Admin</label>
            <input 
              type="password" 
              className={`w-full px-4 py-2.5 rounded-xl border focus:ring-2 focus:ring-blue-500 outline-none transition-all font-kanit ${isDarkMode ? 'bg-slate-900 border-slate-600 text-white' : 'bg-slate-50 border-slate-200 text-slate-900'}`}
              value={password}
              onChange={(e) => setPassword(e.target.value)}
              placeholder="กรุณากรอกรหัสผ่าน (1234)"
              autoFocus
            />
          </div>
          {error && <p className="text-rose-500 text-xs font-kanit flex items-center gap-1"><AlertTriangle size={12}/> {error}</p>}
          <button 
            type="submit"
            className="w-full py-3 rounded-xl bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-bold font-kanit transition-all shadow-lg shadow-blue-500/30"
          >
            เข้าสู่ระบบ
          </button>
        </form>
      </div>
    </div>
  );
};

export default function App() {
  const [rawData, setRawData] = useState([]);
  const [data, setData] = useState([]);
  const [isLoading, setIsLoading] = useState(false);
  const [lastUpdated, setLastUpdated] = useState(null);
  const [error, setError] = useState(null);
  
  const [isDarkMode, setIsDarkMode] = useState(true); // Default to Dark Mode for Dashboard feel
  const [activeTab, setActiveTab] = useState('dashboard');
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [showLoginModal, setShowLoginModal] = useState(false);
  const [isSidebarOpen, setIsSidebarOpen] = useState(false);

  // Filters State based on requested columns
  const [filters, setFilters] = useState({
    salesRep: [],      // BB
    customerGroup: [], // AZ
    customerCode: [],  // R
    month: []          // AU
  });

  const fetchData = async () => {
    setIsLoading(true);
    setError(null);
    try {
      const response = await fetch(GOOGLE_SHEET_CSV_URL);
      if (!response.ok) throw new Error('Failed to fetch data');
      
      const text = await response.text();
      const parsed = parseCSV(text);
      
      if (parsed.length > 0) {
        setRawData(parsed);
        setLastUpdated(new Date());
      } else {
        throw new Error('No data found in CSV');
      }
    } catch (err) {
      console.error("Error fetching Google Sheet:", err);
      setError("ไม่สามารถเชื่อมต่อ Google Sheet ได้ กรุณาตรวจสอบสิทธิ์การแชร์ไฟล์");
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    fetchData();
  }, []);

  // Application of Filters
  useEffect(() => {
    let result = rawData;
    if (filters.salesRep.length > 0) result = result.filter(item => filters.salesRep.includes(item['BB']));
    if (filters.customerGroup.length > 0) result = result.filter(item => filters.customerGroup.includes(item['AZ']));
    if (filters.customerCode.length > 0) result = result.filter(item => filters.customerCode.includes(item['R']));
    if (filters.month.length > 0) result = result.filter(item => filters.month.includes(item['AU']));
    setData(result);
  }, [filters, rawData]);

  const handleNavClick = (tab) => {
    if (tab === 'list' && !isAuthenticated) {
      setShowLoginModal(true);
    } else {
      setActiveTab(tab);
      setIsSidebarOpen(false);
    }
  };

  const handleLoginSuccess = () => {
    setIsAuthenticated(true);
    setShowLoginModal(false);
    setActiveTab('list');
    setIsSidebarOpen(false);
  };

  // --- Extract unique filter options ---
  // กรองหัวตารางและคำที่ผู้ใช้ต้องการเอาออก
  const uniqueSalesRep = useMemo(() => {
      const excludeList = ['ecommerce', 'e-commerce', 'sevice center', 'service center', 'other', 'ผู้แทนขาย'];
      return [...new Set(rawData.map(d => d['BB']).filter(v => {
          if (!v) return false;
          return !excludeList.includes(v.toLowerCase().trim());
      }))].sort();
  }, [rawData]);
  
  const uniqueCustomerGroup = useMemo(() => {
      return [...new Set(rawData.map(d => d['AZ']).filter(v => v && v.trim() !== 'Customer group'))].sort();
  }, [rawData]);
  
  const uniqueCustomerCode = useMemo(() => {
      return [...new Set(rawData.map(d => d['R']).filter(v => v && v.trim() !== 'รหัสลูกค้า' && v.trim() !== 'Customer Code'))].sort();
  }, [rawData]);
  
  const uniqueMonth = useMemo(() => {
      return [...new Set(rawData.map(d => d['AU']).filter(v => v && v.trim() !== 'Month'))];
  }, [rawData]); 

  // --- Calculations for Top Cards ---
  const summary = useMemo(() => {
    let lineItem = 0;
    let complete = 0;
    let failed = 0;
    let inTransit = 0;

    data.forEach(row => {
        // ข้ามแถวที่เป็นหัวตาราง
        if (row['AT'] === 'Line item' || row['AT'] === 'AT') return;

        const val = parseCurrency(row['AT']);
        const status = (row['AR'] || '').toString().trim().toLowerCase();
        
        lineItem += val;
        
        if (status.includes('complete')) {
            complete += val;
        } 
        else if (status.includes('failed')) {
            failed += val;
        }
        else if (status === '-') {
            inTransit += val;
        }
    });

    return { lineItem, complete, failed, inTransit };
  }, [data]);

  // --- Calculations for Region Cards (Column AC) & Root Causes (Column AW) ---
  const regionDataArray = useMemo(() => {
    const regionMap = {};
    const excludeRegions = ['e-commerce', 'ecommerce', 'ไม่ระบุ', 'region'];

    data.forEach(row => {
        const regionRaw = (row['AC'] || 'ไม่ระบุ').toString().trim();
        if (excludeRegions.includes(regionRaw.toLowerCase())) return; // ตัดการ์ดภูมิภาคที่ไม่ต้องการ

        const region = regionRaw;
        const val = parseCurrency(row['AT']);
        const status = (row['AR'] || '').toString().trim().toLowerCase();
        const rootCause = row['AW'] || 'ไม่มีข้อมูล/ไม่ระบุ';

        if (!regionMap[region]) {
            regionMap[region] = { 
                name: region, 
                total: 0, 
                complete: 0, 
                failed: 0, 
                inTransit: 0,
                rootCauses: {},
                rootCauseTotalCount: 0 // เพิ่มตัวแปรเก็บยอดรวมของ root cause ทั้งหมดในภาคนั้น
            };
        }

        regionMap[region].total += val;
        if (status.includes('complete')) regionMap[region].complete += val;
        else if (status.includes('failed')) regionMap[region].failed += val;
        else if (status === '-') regionMap[region].inTransit += val;

        // นับ Root Cause (เฉพาะรายการที่มีปัญหาหรือ Failed)
        if (status.includes('failed') || (rootCause !== 'ไม่มีข้อมูล/ไม่ระบุ' && rootCause.trim() !== 'Root Cause')) {
           regionMap[region].rootCauses[rootCause] = (regionMap[region].rootCauses[rootCause] || 0) + 1;
           regionMap[region].rootCauseTotalCount += 1; // นับรวมจำนวนเคสที่มี root cause
        }
    });

    // Format Data & Find Top 3 Root Causes per region
    return Object.values(regionMap)
        .sort((a, b) => b.total - a.total)
        .map(region => {
            const topRC = Object.entries(region.rootCauses)
                .filter(([rc]) => rc.trim() !== '')
                .sort((a, b) => b[1] - a[1]) // Sort by count descending
                .slice(0, 3)
                .map(([rcName, count]) => {
                    // คำนวณ % จากยอดรวม root cause ของภาคนั้น
                    const pct = region.rootCauseTotalCount > 0 
                        ? ((count / region.rootCauseTotalCount) * 100).toFixed(1) 
                        : 0;
                    return { name: rcName, count, pct };
                });
            
            const totalVal = region.total > 0 ? region.total : 1;
            
            return { 
                ...region, 
                topRC,
                completePct: Number(((region.complete / totalVal) * 100).toFixed(1)),
                failedPct: Number(((region.failed / totalVal) * 100).toFixed(1)),
                inTransitPct: Number(((region.inTransit / totalVal) * 100).toFixed(1))
            };
        });

  }, [data]);

  // --- Chart Data: Month to Month Comparison ---
  const monthToMonthData = useMemo(() => {
      const group = {};
      data.forEach(row => {
          const month = row['AU'] ? row['AU'].trim() : '';
          // ข้ามถ้าว่างเปล่าหรือเป็นหัวตาราง
          if (!month || month === 'Month') return;
          
          const val = parseCurrency(row['AT']);
          const status = (row['AR'] || '').toString().trim().toLowerCase();

          if (!group[month]) group[month] = { name: month, total: 0, complete: 0, failed: 0, inTransit: 0 };
          
          group[month].total += val;

          // แยกเก็บข้อมูลตามสถานะ
          if (status.includes('complete')) {
              group[month].complete += val;
          } else if (status.includes('failed')) {
              group[month].failed += val;
          } else if (status === '-') {
              group[month].inTransit += val;
          }
      });

      // จัดเรียงตามลำดับเดือน (ถ้าชื่อตรง)
      const monthOrder = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
      return Object.values(group).sort((a, b) => {
          const idxA = monthOrder.indexOf(a.name);
          const idxB = monthOrder.indexOf(b.name);
          if (idxA !== -1 && idxB !== -1) return idxA - idxB;
          return 0;
      }).map(item => ({
          ...item,
          // คำนวณเป็น % โดยนำค่าย่อยหารด้วยยอดเต็ม (total) คูณ 100
          completePct: item.total > 0 ? Number(((item.complete / item.total) * 100).toFixed(1)) : 0,
          failedPct: item.total > 0 ? Number(((item.failed / item.total) * 100).toFixed(1)) : 0,
          inTransitPct: item.total > 0 ? Number(((item.inTransit / item.total) * 100).toFixed(1)) : 0,
      }));
  }, [data]);

  // --- Chart Data: SLA Status ---
  const statusPieData = useMemo(() => {
      return [
          { name: 'Complete', value: summary.complete },
          { name: 'Failed', value: summary.failed },
          { name: 'In Transit', value: summary.inTransit },
          { name: 'Other', value: summary.lineItem - summary.complete - summary.failed - summary.inTransit }
      ].filter(d => d.value > 0);
  }, [summary]);

  const COLORS = ['#10b981', '#f43f5e', '#f59e0b', '#64748b', '#3b82f6', '#8b5cf6'];
  const THEME_CLASSES = isDarkMode ? 'bg-slate-950 text-white' : 'bg-[#f1f5f9] text-slate-800';

  return (
    <div className={`flex h-screen font-kanit overflow-hidden transition-colors duration-300 ${THEME_CLASSES}`}>
      <style>
        {`
          @import url('https://fonts.googleapis.com/css2?family=Kanit:wght@200;300;400;500;600;700&display=swap');
          .font-kanit { font-family: 'Kanit', sans-serif; }
          ::-webkit-scrollbar { width: 6px; height: 6px; }
          ::-webkit-scrollbar-track { background: transparent; }
          ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 4px; }
          ::-webkit-scrollbar-thumb:hover { background: #64748b; }
        `}
      </style>

      <LoginModal 
        isOpen={showLoginModal} 
        onClose={() => setShowLoginModal(false)} 
        onLogin={handleLoginSuccess}
        isDarkMode={isDarkMode}
      />
      
      {isSidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/60 z-40 lg:hidden backdrop-blur-sm"
          onClick={() => setIsSidebarOpen(false)}
        />
      )}

      {/* --- SIDEBAR (Filters Area) --- */}
      <aside className={`fixed inset-y-0 left-0 z-50 w-72 transform transition-transform duration-300 ease-in-out lg:translate-x-0 lg:static flex flex-col shadow-2xl ${isSidebarOpen ? 'translate-x-0' : '-translate-x-full'} ${isDarkMode ? 'bg-slate-900 border-r border-slate-800' : 'bg-white border-r border-slate-200'}`}>
        
        <div className="p-6 pb-4 shrink-0 border-b border-slate-100 dark:border-slate-800/50">
          <div className="flex items-center gap-3">
            <div className="bg-gradient-to-br from-indigo-500 to-blue-600 p-2.5 rounded-xl shadow-lg shadow-blue-500/30">
              <Activity size={24} className="text-white" />
            </div>
            <div>
