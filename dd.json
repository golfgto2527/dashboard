                             <XAxis dataKey="name" tick={{ fontSize: 11, fill: isDarkMode ? '#94a3b8' : '#64748b' }} axisLine={false} tickLine={false} />
                             {/* แกน Y ซ้ายสำหรับยอดรวม Line Item */}
                             <YAxis yAxisId="left" tickFormatter={(val) => val.toLocaleString()} tick={{ fontSize: 10, fill: isDarkMode ? '#94a3b8' : '#64748b' }} axisLine={false} tickLine={false} />
                             {/* แกน Y ขวาสำหรับเปอร์เซ็นต์ (%) */}
                             <YAxis yAxisId="right" orientation="right" tickFormatter={(val) => `${val}%`} tick={{ fontSize: 10, fill: isDarkMode ? '#94a3b8' : '#64748b' }} axisLine={false} tickLine={false} />
                             <RechartsTooltip 
                                 contentStyle={{ borderRadius: '12px', border: 'none', backgroundColor: isDarkMode ? '#1e293b' : '#fff', color: isDarkMode ? '#fff' : '#000', boxShadow: '0 10px 15px -3px rgba(0, 0, 0, 0.1)' }}
                                 formatter={(value, name) => {
                                     // ถ้าชื่อข้อมูลมีคำว่า (%) ให้ใส่เครื่องหมาย % ต่อท้ายตัวเลข
                                     if (name.includes('%')) return [`${value}%`, name];
                                     return [value.toLocaleString(), name];
                                 }}
                             />
                             <Legend wrapperStyle={{ fontSize: '12px' }} />
                             <Bar yAxisId="left" dataKey="total" name="Line Item (รวม)" fill="#3b82f6" radius={[4, 4, 0, 0]} />
                             <Bar yAxisId="right" dataKey="completePct" name="Complete (%)" fill="#10b981" radius={[4, 4, 0, 0]} />
                             <Bar yAxisId="right" dataKey="failedPct" name="Failed (%)" fill="#f43f5e" radius={[4, 4, 0, 0]} />
                             <Bar yAxisId="right" dataKey="inTransitPct" name="In Transit (%)" fill="#f59e0b" radius={[4, 4, 0, 0]} />
                             {/* เส้น Trend Line สำหรับ Complete และ Failed (แบบเปอร์เซ็นต์) */}
                             <Line yAxisId="right" type="monotone" dataKey="completePct" name="Trend Complete (%)" stroke="#10b981" strokeWidth={3} dot={{ r: 4, strokeWidth: 2, fill: isDarkMode ? '#1e293b' : '#fff' }} activeDot={{ r: 6 }} />
                             <Line yAxisId="right" type="monotone" dataKey="failedPct" name="Trend Failed (%)" stroke="#f43f5e" strokeWidth={3} dot={{ r: 4, strokeWidth: 2, fill: isDarkMode ? '#1e293b' : '#fff' }} activeDot={{ r: 6 }} />
                          </ComposedChart>
                       </ResponsiveContainer>
                    </div>
                 </div>

              </div>
            </div>
          )}

          {/* --- RAW DATA LIST --- */}
          {activeTab === 'list' && isAuthenticated && (
